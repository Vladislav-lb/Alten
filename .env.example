ALTEN_EMS_HOST=0.0.0.0
ALTEN_EMS_PORT=8000
ALTEN_EMS_CORS_ORIGINS=*
ALTEN_EMS_DATA_DIR=./backend/data

# Optional real MQTT broker. Leave empty for dry-run mode.
ALTEN_EMS_MQTT_HOST=
ALTEN_EMS_MQTT_PORT=1883
ALTEN_EMS_MQTT_USERNAME=
ALTEN_EMS_MQTT_PASSWORD=

# Optional Modbus TCP gateway defaults.
ALTEN_EMS_MODBUS_HOST=
ALTEN_EMS_MODBUS_PORT=502
ALTEN_EMS_MODBUS_UNIT=1

# Home Assistant Core API. In add-on mode, SUPERVISOR_TOKEN is provided by Home Assistant.
ALTEN_EMS_HA_URL=http://supervisor/core/api
ALTEN_EMS_HA_TOKEN=

# Optional Ukrainian DAM/RDN price API from Market Operator.
ALTEN_EMS_OREE_API_KEY=
ALTEN_EMS_OREE_PRICES_URL=https://www.oree.com.ua/index.php/api/damprices
ALTEN_EMS_OREE_ZONE_EIC=10Y1001C--000182
ALTEN_EMS_OREE_DATE_PARAM=date
